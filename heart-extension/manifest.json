{
  "manifest_version": 3,
  "name": "Heartbeat Extension",
  "version": "1.0",
  "description": "Adds a resizable, vibrating pixelated heart to your browser corner.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
